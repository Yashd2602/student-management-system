# ---- Server ----
PORT=5000

# Comma separated list of allowed origins for CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173

# ---- PostgreSQL connection ----
# Either use a single connection string...
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/student_db

# ...or the individual variables below (used when DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=student_db

# Max file size for student photo uploads (in bytes). Default 2 MB.
MAX_UPLOAD_BYTES=2097152
